# Local Development Environment Variables
# Copy this file to .dev.vars and fill in your values

# GitHub OAuth App (Development)
# Create at: https://github.com/settings/developers
# Homepage URL: http://localhost:8788
# Callback URL: http://localhost:8788/callback
OAUTH_GITHUB_CLIENT_ID=your_development_github_client_id
OAUTH_GITHUB_CLIENT_SECRET=your_development_github_client_secret

# Cookie Encryption Key
# Generate with: openssl rand -hex 32
COOKIE_ENCRYPTION_KEY=your_random_encryption_key_here
